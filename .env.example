# Database
DATABASE_URI=postgresql://schedulio:davelopment2026!@localhost:5432/schedulio
POSTGRES_USER=schedulio
POSTGRES_PASSWORD=davelopment2026!
POSTGRES_DB=schedulio
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Payload CMS
PAYLOAD_SECRET=your-secret-key-here-change-this-in-production
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Next.js
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth (Google/Facebook)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# Email (Resend)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@davelopment.hu
RESEND_FROM_NAME=davelopment booking

# Image Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=/public/uploads

# JWT
JWT_SECRET=your-jwt-secret-key-here-change-this-in-production

# Admin Panel
ADMIN_USER_EMAIL=admin@davelopment.hu
ADMIN_USER_PASSWORD=change-this-in-production

# Stripe (fizetés) — teszt-kulcsok a Stripe Dashboard → Developers → API keys alól.
# A webhook secret: Stripe CLI (`stripe listen --forward-to localhost:3000/api/stripe/webhook`)
# vagy a Dashboard → Webhooks → endpoint aláírás-titka. Nélkülük a fizetés némán ki van kapcsolva.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Számlázz.hu (számlázás) — a Számla Agent kulcs a fiók vezérlőpultján generálható (kulcs ikon).
# CSAK kisbetűs; a kulccsal weboldalra nem lehet belépni, csak API-hívásra jó. Nélküle a Stripe
# fizetés utáni automata számlázás némán kimarad (a fizetés attól még működik).
# SZAMLAZZ_INVOICE_TEST=true → a hívás NEM állít ki éles, NAV-nak bejelentett számlát (fejlesztéshez).
SZAMLAZZ_AGENT_KEY=
SZAMLAZZ_INVOICE_TEST=true

# Cron — az emlékeztető/visszajelzés ütemező védelme (VPS-cron a /api/cron/notifications-t hívja ezzel).
CRON_SECRET=change-this-in-production

# Web Push (VAPID) — self-hosted, INGYENES böngésző-push (nincs 3rd-party szolgáltatás).
# Kulcspár generálása egyszer: `node -e "console.log(require('web-push').generateVAPIDKeys())"`
# A PUBLIC kulcs a kliensbe is megy (NEXT_PUBLIC_…), a PRIVATE CSAK a szerveren marad.
# A SUBJECT egy mailto: vagy https: URL (a push-szolgáltatók kontakt-infója).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello.davelopment@gmail.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
