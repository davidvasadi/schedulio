# Database
DATABASE_URI=postgresql://schedulio:davelopment2026!@localhost:5432/schedulio
POSTGRES_USER=schedulio
POSTGRES_PASSWORD=davelopment2026!
POSTGRES_DB=schedulio
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Payload CMS
PAYLOAD_SECRET=your-secret-key-here-change-this-in-production
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Next.js
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth (Google/Facebook)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# Email (Resend)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@davelopment.hu
RESEND_FROM_NAME=Schedulio

# Image Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=/public/uploads

# JWT
JWT_SECRET=your-jwt-secret-key-here-change-this-in-production

# Admin Panel
ADMIN_USER_EMAIL=admin@davelopment.hu
ADMIN_USER_PASSWORD=change-this-in-production
